rules_version = '2';

// ============================================================
// Caramello Kids — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules
//
// Изисква Firebase Authentication (анонимна или пълна).
// Роли се задават чрез Firebase Auth Custom Claims:
//   { role: "manager" | "waiter" | "animator" }
// Задаване на роля (Cloud Function или Admin SDK):
//   admin.auth().setCustomUserClaims(uid, { role: "manager" })
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Помощни функции ──────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.get('role', 'none');
    }

    function isManager() {
      return isAuth() && role() == 'manager';
    }

    function isWaiter() {
      return isAuth() && role() == 'waiter';
    }

    function isAnimator() {
      return isAuth() && role() == 'animator';
    }

    function isStaff() {
      return isManager() || isWaiter() || isAnimator();
    }

    // ── Резервации ────────────────────────────────────────────
    // Мениджър: пълен достъп
    // Сервитьор: четене на всички, само създаване (без редакция/изтриване)
    // Аниматор: само резервации в зони kids и paintball
    match /reservations/{resId} {
      allow read: if isManager() || isWaiter() ||
        (isAnimator() && resource.data.zone in ['kids', 'paintball']);

      allow create: if isManager() || isWaiter() ||
        (isAnimator() && request.resource.data.zone in ['kids', 'paintball']);

      allow update, delete: if isManager();
    }

    // ── Маси / Tables ─────────────────────────────────────────
    match /tables/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // ── Менюта ────────────────────────────────────────────────
    match /menuItems/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // ── Одит лог ─────────────────────────────────────────────
    // Четене само за мениджър; създаване за всеки персонал;
    // редакция/изтриване на одит записи е забранено
    match /audit/{docId} {
      allow read: if isManager();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // ── Потребители (персонал) ────────────────────────────────
    match /users/{userId} {
      allow read, write: if isManager();
    }

    // ── Онлайн резервации от booking.html ─────────────────────
    // Публичният формуляр изпраща към Supabase, не тук.
    // Ако бъде мигриран към Firestore, добавете:
    // match /online_bookings/{docId} {
    //   allow create: if true; // публично създаване
    //   allow read, update, delete: if isManager();
    // }

    // ── Отказ по подразбиране ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
