rules_version = '2';

// ============================================================
// Caramello Kids — Firestore Security Rules
//
// Как работи:
//   1. Приложението използва Firebase Anonymous Auth.
//   2. При вход потребителят записва ролята си в users/{uid}.role
//   3. Rules четат тази роля чрез get() при всяка заявка.
//
// Deploy: firebase deploy --only firestore:rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Помощни функции ──────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // Чете ролята от users/{uid} в Firestore
    function getRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.exists() ? userDoc.data.get('role', 'none') : 'none';
    }

    function isManager() { return isAuth() && getRole() == 'manager'; }
    function isWaiter()  { return isAuth() && getRole() == 'waiter';  }
    function isAnimator(){ return isAuth() && getRole() == 'animator';}
    function isStaff()   { return isManager() || isWaiter() || isAnimator(); }

    // Помощна функция — true ако users/{uid} документът все още не съществува.
    // Използва се за fallback докато doLogin() не запише ролята за първи път.
    function noUserDoc() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // ── Потребители ───────────────────────────────────────────
    // Всеки логнат потребител може да запише САМО собствения си документ
    // (doLogin() го прави при всеки вход).
    // Само мениджърът може да чете всички потребители.
    match /users/{userId} {
      allow read:  if isAuth() && (request.auth.uid == userId || isManager());
      // write не изисква роля — нужно е за първоначалното създаване на документа
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── Резервации ────────────────────────────────────────────
    // Мениджър:  пълен достъп
    // Сервитьор: чете всички, само създава (без редакция/изтриване)
    // Аниматор:  само Kids и Paintball зони
    // Fallback:  ако users/{uid} още не съществува (първи вход, race condition)
    //            → позволи четене на логнат потребител докато ролята се запише
    match /reservations/{resId} {
      allow read:
        if isManager()
        || isWaiter()
        || (isAnimator() && resource.data.get('zone', 'indoor') in ['kids', 'paintball'])
        || (isAuth() && noUserDoc());

      allow create:
        if isManager()
        || isWaiter()
        || (isAnimator() && request.resource.data.get('zone', 'indoor') in ['kids', 'paintball'])
        || (isAuth() && noUserDoc());

      allow update, delete:
        if isManager()
        || (isAuth() && noUserDoc());
    }

    // ── Маси ─────────────────────────────────────────────────
    match /tables/{docId} {
      allow read:  if isStaff();
      allow write: if isManager();
    }

    // ── Меню ─────────────────────────────────────────────────
    match /menuItems/{docId} {
      allow read:  if isStaff();
      allow write: if isManager();
    }

    // ── Одит лог (immutable) ──────────────────────────────────
    match /audit/{docId} {
      allow read:           if isManager();
      allow create:         if isStaff();
      allow update, delete: if false;
    }

    // ── Отказ по подразбиране ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
